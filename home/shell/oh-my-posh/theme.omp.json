{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 2,
  "final_space": true,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "session",
          "style": "plain",
          "foreground": "#000000",
          "template": "\n{{ .UserName }} "
        },
        {
          "type": "path",
          "style": "plain",
          "foreground": "#000000",
          "template": "{{ .Path }} ",
          "properties": {
            "style": "full",
            "mapped_locations": {
              "~": "~"
            }
          }
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "#000000",
          "template": "({{ .HEAD }}) ",
          "properties": {
            "branch_icon": " ",
            "fetch_status": true,
            "fetch_upstream": true
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "#000000",
          "template": "❯ "
        }
      ]
    }
  ]
}
